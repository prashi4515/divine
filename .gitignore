# =========================================================================
# Divine — root .gitignore
# Keep the repo clean: only source, config, and docs are tracked.
# =========================================================================

# ---- Dependencies -------------------------------------------------------
node_modules
.pnpm-store
.pnpm-debug.log*

# ---- Build outputs ------------------------------------------------------
dist
build
out
.next
.turbo
.cache
coverage
*.tsbuildinfo

# ---- Environment / secrets ---------------------------------------------
# Never commit real env files. .env.example is the only tracked one.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
!.env.example

# ---- Logs ---------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Uploads ------------------------------------------------------------
uploads/
apps/api/uploads/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea

# ---- Testing ------------------------------------------------------------
.nyc_output
playwright-report
test-results

# ---- Misc ---------------------------------------------------------------
*.tgz
tmp
temp
.tmp/
nest
