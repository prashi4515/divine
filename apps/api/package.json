{
  "name": "@divine/api",
  "version": "0.0.0",
  "private": true,
  "description": "Divine backend API — NestJS foundation (Prisma, Swagger, health, logging).",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "verify:db": "node --env-file=.env scripts/verify-db.mts",
    "prisma:seed": "node --env-file=.env scripts/seed.mts",
    "cms:sync": "node --env-file=.env scripts/sync-cms-from-works.mts",
    "indic:import": "node --env-file=.env scripts/import-indic-translations.mts",
    "commentary:import": "node --env-file=.env scripts/import-commentaries.mts",
    "commentary:multilang": "node --env-file=.env scripts/import-multilang-commentaries.mts",
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@divine/types": "workspace:*",
    "@indic-transliteration/sanscript": "^1.3.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "nestjs-pino": "^4.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^8.57.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "vitest": "^3.0.5"
  },
  "prisma": {
    "seed": "node --env-file=.env scripts/seed.mts"
  }
}
