# =========================================================================
# apps/api — environment variables (example)
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# All first-party variables are prefixed DIVINE_ to avoid collisions.
# Every variable here is validated at boot by src/config/env.ts (Zod).
# =========================================================================

# Runtime environment: development | test | production
NODE_ENV=development

# Port the HTTP server listens on.
DIVINE_API_PORT=8080

# -------------------------------------------------------------------------
# PostgreSQL (Neon)
#
# Neon exposes TWO endpoints for the same database:
#   • POOLED  host contains "-pooler"  -> use at RUNTIME (this is `url`)
#   • DIRECT  host has NO "-pooler"     -> use for MIGRATIONS (`directUrl`)
#
# Copy both strings from the Neon dashboard → Connection Details.
# Keep `sslmode=require`. Never commit the real values.
# -------------------------------------------------------------------------

# Runtime (pooled). Example shape — replace with YOUR Neon pooled string:
DIVINE_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/divine?sslmode=require

# Migrations (direct, non-pooled). Example shape — replace with YOUR direct string:
DIVINE_DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/divine?sslmode=require

# Local alternative (docker-compose Postgres) — pooled and direct are identical:
# DIVINE_DATABASE_URL=postgresql://divine:divine@localhost:5432/divine?schema=public
# DIVINE_DIRECT_URL=postgresql://divine:divine@localhost:5432/divine?schema=public

# Allowed browser origin for CORS (the web app). Use a comma-free single origin
# for now; expand handling later if multiple origins are needed.
DIVINE_WEB_ORIGIN=http://localhost:3000

# Log level: fatal | error | warn | info | debug | trace
DIVINE_LOG_LEVEL=info
