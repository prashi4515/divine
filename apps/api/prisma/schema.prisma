// =========================================================================
// Divine — Prisma schema
//
// P0 content catalog: Work, Chapter, Verse, Language, TranslationSource,
//                     Translation, Topic, VerseTopic, Emotion, VerseEmotion
// P1 auth + CMS library: User, AuthIdentity, RefreshToken, PasswordResetToken,
//                        Scripture, ScriptureNode, MediaAsset
// =========================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DIVINE_DATABASE_URL")
  directUrl = env("DIVINE_DIRECT_URL")
}

// -------------------------------------------------------------------------
// Work — a scripture / corpus (Bhagavad Gita first; more later)
// Public identity: `code` (e.g. "bg")
// -------------------------------------------------------------------------
model Work {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(32)
  slug        String   @unique @db.VarChar(64)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  /// draft | review | published | archived
  status      String   @default("draft") @db.VarChar(32)
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  chapters   Chapter[]
  scriptures Scripture[]

  @@index([isPublished, sortOrder])
  @@index([status])
  @@map("works")
}

// -------------------------------------------------------------------------
// Chapter — structural unit within a work (locale-independent)
// Public identity: `publicId` (e.g. "bg.2")
// -------------------------------------------------------------------------
model Chapter {
  id          String   @id @default(uuid()) @db.Uuid
  workId      String   @map("work_id") @db.Uuid
  number      Int
  publicId    String   @unique @map("public_id") @db.VarChar(64)
  /// Optional English/editorial title for ops; localized titles come later.
  title       String?  @db.VarChar(255)
  verseCount  Int      @default(0) @map("verse_count")
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  work   Work    @relation(fields: [workId], references: [id], onDelete: Cascade)
  verses Verse[]

  @@unique([workId, number])
  @@index([workId, sortOrder])
  @@index([isPublished])
  @@map("chapters")
}

// -------------------------------------------------------------------------
// Verse — atomic scripture unit
// Public identity: `publicId` (e.g. "bg.2.47") — immutable once published
// Sanskrit + transliteration live here; meaning lives in Translation
// -------------------------------------------------------------------------
model Verse {
  id              String   @id @default(uuid()) @db.Uuid
  chapterId       String   @map("chapter_id") @db.Uuid
  number          Int
  publicId        String   @unique @map("public_id") @db.VarChar(64)
  /// Original-language text (Sanskrit, Arabic, Hebrew, etc.)
  sanskritText    String   @map("sanskrit_text") @db.Text
  transliteration String?  @db.Text
  /// Editorial meaning / short reflection (CMS-editable)
  meaning         String?  @db.Text
  /// Optional longer commentary
  commentary      String?  @db.Text
  seoTitle        String?  @map("seo_title") @db.VarChar(255)
  seoDescription  String?  @map("seo_description") @db.Text
  sortOrder       Int      @default(0) @map("sort_order")
  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  chapter       Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  translations  Translation[]
  verseTopics   VerseTopic[]
  verseEmotions VerseEmotion[]
  revisions     ContentRevision[]

  @@unique([chapterId, number])
  @@index([chapterId, sortOrder])
  @@index([isPublished])
  @@map("verses")
}

// -------------------------------------------------------------------------
// ContentRevision — simple version history snapshots for CMS edits
// -------------------------------------------------------------------------
model ContentRevision {
  id         String   @id @default(uuid()) @db.Uuid
  /// verse | translation | scripture
  entityType String   @map("entity_type") @db.VarChar(32)
  entityId   String   @map("entity_id") @db.Uuid
  verseId    String?  @map("verse_id") @db.Uuid
  snapshot   Json
  note       String?  @db.VarChar(255)
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  verse Verse? @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([verseId, createdAt])
  @@map("content_revisions")
}

// -------------------------------------------------------------------------
// Language — BCP-47 catalog (en, hi, ta, …)
// Replaces free-form locale strings on content rows
// -------------------------------------------------------------------------
model Language {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(16)
  name        String   @db.VarChar(128)
  nativeName  String?  @map("native_name") @db.VarChar(128)
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  translations Translation[]

  @@index([isPublished, sortOrder])
  @@map("languages")
}

// -------------------------------------------------------------------------
// TranslationSource — which translator / edition (independent of language)
// -------------------------------------------------------------------------
model TranslationSource {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(64)
  displayName String   @map("display_name") @db.VarChar(255)
  author      String?  @db.VarChar(255)
  license     String?  @db.VarChar(255)
  isDefault   Boolean  @default(false) @map("is_default")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  translations Translation[]

  @@index([isPublished])
  @@map("translation_sources")
}

// -------------------------------------------------------------------------
// Translation — meaning of a verse in a language from a given source
// -------------------------------------------------------------------------
model Translation {
  id                  String   @id @default(uuid()) @db.Uuid
  verseId             String   @map("verse_id") @db.Uuid
  languageId          String   @map("language_id") @db.Uuid
  translationSourceId String   @map("translation_source_id") @db.Uuid
  text                String   @db.Text
  isPublished         Boolean  @default(false) @map("is_published")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  verse             Verse             @relation(fields: [verseId], references: [id], onDelete: Cascade)
  language          Language          @relation(fields: [languageId], references: [id], onDelete: Restrict)
  translationSource TranslationSource @relation(fields: [translationSourceId], references: [id], onDelete: Restrict)

  @@unique([verseId, languageId, translationSourceId])
  @@index([languageId, translationSourceId])
  @@index([verseId, isPublished])
  @@map("translations")
}

// -------------------------------------------------------------------------
// Topic — thematic taxonomy (duty, devotion, …); optional hierarchy
// -------------------------------------------------------------------------
model Topic {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  parent   Topic?  @relation("TopicHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Topic[] @relation("TopicHierarchy")

  verseTopics VerseTopic[]

  @@index([parentId])
  @@index([isPublished, sortOrder])
  @@map("topics")
}

// -------------------------------------------------------------------------
// VerseTopic — many-to-many Verse ↔ Topic
// -------------------------------------------------------------------------
model VerseTopic {
  id        String   @id @default(uuid()) @db.Uuid
  verseId   String   @map("verse_id") @db.Uuid
  topicId   String   @map("topic_id") @db.Uuid
  weight    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  verse Verse @relation(fields: [verseId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([verseId, topicId])
  @@index([topicId, verseId])
  @@map("verse_topics")
}

// -------------------------------------------------------------------------
// Emotion — emotion-based discovery catalog (anxiety, clarity, …)
// -------------------------------------------------------------------------
model Emotion {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  verseEmotions VerseEmotion[]

  @@index([isPublished, sortOrder])
  @@map("emotions")
}

// -------------------------------------------------------------------------
// VerseEmotion — many-to-many Verse ↔ Emotion
// -------------------------------------------------------------------------
model VerseEmotion {
  id        String   @id @default(uuid()) @db.Uuid
  verseId   String   @map("verse_id") @db.Uuid
  emotionId String   @map("emotion_id") @db.Uuid
  weight    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  verse   Verse   @relation(fields: [verseId], references: [id], onDelete: Cascade)
  emotion Emotion @relation(fields: [emotionId], references: [id], onDelete: Cascade)

  @@unique([verseId, emotionId])
  @@index([emotionId, verseId])
  @@map("verse_emotions")
}

// -------------------------------------------------------------------------
// User — account root for admin CMS (and future public accounts)
// -------------------------------------------------------------------------
model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(320)
  emailVerifiedAt   DateTime? @map("email_verified_at") @db.Timestamptz(3)
  displayName       String    @map("display_name") @db.VarChar(255)
  avatarUrl         String?   @map("avatar_url") @db.Text
  /// Role slugs matching the web RBAC catalog (e.g. "super-admin").
  roles             String[]  @default([])
  /// active | invited | suspended | deactivated
  status            String    @default("active") @db.VarChar(32)
  preferredLanguage String?   @map("preferred_language") @db.VarChar(16)
  timeZone          String?   @map("time_zone") @db.VarChar(64)
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  identities          AuthIdentity[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([status])
  @@map("users")
}

model AuthIdentity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  /// password | google | apple
  provider        String  @db.VarChar(32)
  providerSubject String  @map("provider_subject") @db.VarChar(320)
  passwordHash   String?  @map("password_hash") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_identities")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  rememberMe Boolean   @default(false) @map("remember_me")
  userAgent  String?   @map("user_agent") @db.Text
  ip         String?   @db.VarChar(64)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// -------------------------------------------------------------------------
// Scripture — CMS library corpus linked 1:1 to public Work catalog.
// Structure level *labels* are arbitrary (Chapter/Surah/Kanda); content
// lives on Work → Chapter → Verse (single source of truth for the reader).
// -------------------------------------------------------------------------
model Scripture {
  id                String   @id @default(uuid()) @db.Uuid
  /// Linked public Work — CMS edits and public reader share this catalog.
  workId            String?  @unique @map("work_id") @db.Uuid
  name              String   @db.VarChar(255)
  slug              String   @unique @db.VarChar(128)
  shortName         String?  @map("short_name") @db.VarChar(64)
  description       String?  @db.Text
  religion          String?  @db.VarChar(128)
  originalLanguage  String?  @map("original_language") @db.VarChar(64)
  author            String?  @db.VarChar(255)
  estimatedDate     String?  @map("estimated_date") @db.VarChar(128)
  coverImageUrl     String?  @map("cover_image_url") @db.Text
  bannerImageUrl    String?  @map("banner_image_url") @db.Text
  themeColor        String?  @map("theme_color") @db.VarChar(32)
  accentColor       String?  @map("accent_color") @db.VarChar(32)
  seoTitle          String?  @map("seo_title") @db.VarChar(255)
  seoDescription    String?  @map("seo_description") @db.Text
  seoKeywords       String?  @map("seo_keywords") @db.Text
  canonicalUrl      String?  @map("canonical_url") @db.Text
  ogImageUrl        String?  @map("og_image_url") @db.Text
  copyright         String?  @db.Text
  license           String?  @db.VarChar(255)
  website           String?  @db.Text
  /// public | private | unlisted
  visibility        String   @default("private") @db.VarChar(32)
  defaultLanguage   String?  @map("default_language") @db.VarChar(16)
  /// ltr | rtl
  readingDirection  String   @default("ltr") @map("reading_direction") @db.VarChar(8)
  /// Ordered level labels, e.g. ["Chapter","Verse"]
  structureLevels   Json     @default("[]") @map("structure_levels")
  /// draft | review | published | archived
  status            String   @default("draft") @db.VarChar(32)
  isPublished       Boolean  @default(false) @map("is_published")
  sortOrder         Int      @default(0) @map("sort_order")
  bookCount         Int      @default(0) @map("book_count")
  chapterCount      Int      @default(0) @map("chapter_count")
  verseCount        Int      @default(0) @map("verse_count")
  translationCount  Int      @default(0) @map("translation_count")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  work  Work?           @relation(fields: [workId], references: [id], onDelete: SetNull)
  nodes ScriptureNode[]
  media MediaAsset[]

  @@index([isPublished, sortOrder])
  @@index([status])
  @@index([religion])
  @@map("scriptures")
}

model ScriptureNode {
  id          String   @id @default(uuid()) @db.Uuid
  scriptureId String   @map("scripture_id") @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  /// Level label from structureLevels (e.g. "Chapter", "Surah")
  label       String   @db.VarChar(64)
  title       String   @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  scripture Scripture       @relation(fields: [scriptureId], references: [id], onDelete: Cascade)
  parent    ScriptureNode?  @relation("ScriptureNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ScriptureNode[] @relation("ScriptureNodeHierarchy")

  @@index([scriptureId, sortOrder])
  @@index([parentId])
  @@map("scripture_nodes")
}

model MediaAsset {
  id          String   @id @default(uuid()) @db.Uuid
  scriptureId String?  @map("scripture_id") @db.Uuid
  /// cover | banner | icon | illustration | audio | pdf | video | other
  kind        String   @db.VarChar(32)
  fileName    String   @map("file_name") @db.VarChar(255)
  mimeType    String   @map("mime_type") @db.VarChar(128)
  sizeBytes   Int      @default(0) @map("size_bytes")
  /// Storage URL or data placeholder until object storage is wired
  url         String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  scripture Scripture? @relation(fields: [scriptureId], references: [id], onDelete: SetNull)

  @@index([scriptureId, kind])
  @@map("media_assets")
}
