# Server-only API base URL (used by Server Components / RSC data fetching).
DIVINE_API_URL=http://localhost:8080

# Public API base URL (used by the browser for authenticated admin calls).
# Safe to expose — contains no secrets.
NEXT_PUBLIC_DIVINE_API_URL=http://localhost:8080

# Admin auth. Defaults to enabled. Set to false only for emergency local UI work
# without a running auth API.
NEXT_PUBLIC_DIVINE_ADMIN_AUTH_ENABLED=true
