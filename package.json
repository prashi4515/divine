{
  "name": "divine",
  "private": true,
  "version": "0.0.0",
  "description": "Divine — production-grade multilingual Bhagavad Gita platform (monorepo root).",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @divine/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "content:import": "pnpm --filter @divine/content-import load",
    "content:import:dry": "pnpm --filter @divine/content-import load -- --dry-run"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2"
  }
}
